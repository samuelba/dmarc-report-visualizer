{
  "name": "dmarc-frontend",
  "version": "0.8.4",
  "license": "GPL-3.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.local.json",
    "start:docker": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\"",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:codegen": "playwright codegen http://localhost:4200",
    "e2e:report": "playwright show-report"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.2.8",
    "@angular/cdk": "^20.2.8",
    "@angular/common": "^20.2.8",
    "@angular/compiler": "^20.2.8",
    "@angular/core": "^20.2.8",
    "@angular/forms": "^20.2.8",
    "@angular/material": "^20.2.8",
    "@angular/platform-browser": "^20.2.8",
    "@angular/platform-browser-dynamic": "^20.2.8",
    "@angular/router": "^20.2.8",
    "@types/leaflet": "^1.9.20",
    "@types/prismjs": "^1.26.5",
    "chart.js": "^4.5.0",
    "echarts": "^6.0.0",
    "leaflet": "^1.9.4",
    "ng2-charts": "^8.0.0",
    "ngx-echarts": "^20.0.2",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xml-formatter": "^3.6.7",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.3",
    "@analogjs/vitest-angular": "^2.2.3",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/build": "^20.2.8",
    "@angular/cli": "^20.2.8",
    "@angular/compiler-cli": "^20.2.8",
    "@playwright/test": "^1.58.2",
    "@types/echarts": "^4.9.22",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.18.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.2",
    "serve": "^14.2.6",
    "typescript": "~5.8.2",
    "vitest": "^3.1.1"
  }
}
